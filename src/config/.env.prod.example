# Production Environment Variables
# Copy this file to .env.prod and fill in the actual values

# Database Configuration
POSTGRES_DB=novuscapdb
POSTGRES_USER=novuscap_user
POSTGRES_PASSWORD=your_very_secure_database_password_here

# Redis Configuration
REDIS_PASSWORD=your_very_secure_redis_password_here

# JWT Configuration
JWT_SECRET_KEY=your_jwt_secret_key_minimum_32_characters_long_for_security
JWT_ISSUER=NovusCap
JWT_AUDIENCE=NovusCap-Users

# Application URLs
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://api.yourdomain.com

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Email Configuration (if implemented)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# File Storage (if implemented)
# STORAGE_PROVIDER=local
# STORAGE_PATH=/app/uploads

# Monitoring (if implemented)
# SENTRY_DSN=your_sentry_dsn_here

# Security
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Logging
LOG_LEVEL=Warning
ENABLE_STRUCTURED_LOGGING=true
