# =========================================
# NovusCap Application Environment Variables
# =========================================

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=novuscapdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# JWT Configuration
JWT_SECRET_KEY=your_very_secure_jwt_secret_key_at_least_32_characters_long

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_USERNAME=your_email@domain.com
SMTP_PASSWORD=your_app_password

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Application Environment
ASPNETCORE_ENVIRONMENT=Production
NODE_ENV=production

# Frontend Configuration
REACT_APP_API_URL=https://api.novuscap.com
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Security
ALLOWED_HOSTS=novuscap.com,www.novuscap.com

# Logging
LOG_LEVEL=Warning

# Docker Compose Variables
COMPOSE_PROJECT_NAME=novuscap
