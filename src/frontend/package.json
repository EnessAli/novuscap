{
  "name": "novuscap-frontend",
  "version": "1.0.0",
  "description": "Frontend for NovusCap application, a platform for visualizing the entrepreneurship ecosystem in Turkey.",
  "main": "index.js",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "build:prod": "NODE_ENV=production react-scripts build",
    "test": "react-scripts test",
    "test:coverage": "react-scripts test --coverage --watchAll=false",
    "test:ci": "CI=true react-scripts test --coverage --watchAll=false",
    "eject": "react-scripts eject",
    "analyze": "npm run build && npx serve -s build",
    "preview": "npx serve -s build",
    "docker:build": "docker build -t novuscap-frontend .",
    "docker:run": "docker run -p 3000:80 novuscap-frontend"
  },
  "dependencies": {
    "@googlemaps/react-wrapper": "^1.1.35",
    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.0.18",
    "@react-google-maps/api": "^2.20.6",
    "autoprefixer": "^10.4.16",
    "axios": "^1.6.0",
    "classnames": "^2.3.2",
    "date-fns": "^2.30.0",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.48.2",
    "react-query": "^3.39.3",
    "react-router-dom": "^6.8.0",
    "react-scripts": "^5.0.1",
    "react-toastify": "^9.1.3",
    "tailwindcss": "^3.3.6"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-react": "^7.27.1",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "babel-jest": "^30.0.0-beta.3",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "homepage": "https://novuscap.com",
  "proxy": "http://localhost:5000",
  "license": "MIT"
}
