{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Error"
    }
  },
  "AllowedHosts": "novuscap.com,www.novuscap.com",
  "ConnectionStrings": {
    "DefaultConnection": "Host=${POSTGRES_HOST};Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD};Port=${POSTGRES_PORT};SSL Mode=Require;"
  },
  "Jwt": {
    "SecretKey": "${JWT_SECRET_KEY}",
    "Issuer": "NovusCap",
    "Audience": "NovusCapUsers",
    "ExpirationInMinutes": 30,
    "RefreshTokenExpirationInDays": 3
  },
  "EmailSettings": {
    "Host": "${SMTP_HOST}",
    "Port": 587,
    "EnableSsl": true,
    "Username": "${SMTP_USERNAME}",
    "Password": "${SMTP_PASSWORD}"
  },
  "GoogleMaps": {
    "ApiKey": "${GOOGLE_MAPS_API_KEY}"
  },
  "Security": {
    "RequireHttps": true,
    "UseHsts": true,
    "EnableRateLimiting": true
  }
}
