# NovusCap Environment Variables Template
# Copy this file to .env and .env.production and customize the values

# ====================================
# DATABASE CONFIGURATION
# ====================================
DATABASE_URL=Host=localhost;Database=novuscapdb;Username=postgres;Password=your_password
POSTGRES_DB=novuscapdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password

# ====================================
# JWT AUTHENTICATION
# ====================================
JWT_SECRET=your_super_secure_jwt_secret_key_minimum_32_characters
JWT_ISSUER=NovusCap
JWT_AUDIENCE=NovusCapUsers
JWT_EXPIRY_HOURS=24

# ====================================
# API CONFIGURATION
# ====================================
API_BASE_URL=http://localhost:5002
ASPNETCORE_URLS=http://+:5002
ASPNETCORE_ENVIRONMENT=Development

# ====================================
# FRONTEND CONFIGURATION
# ====================================
REACT_APP_API_BASE_URL=http://localhost:5002/api
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
REACT_APP_ENVIRONMENT=development
REACT_APP_APP_NAME=NovusCap
REACT_APP_VERSION=1.0.0

# ====================================
# FEATURE FLAGS
# ====================================
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_MAPS=true
REACT_APP_ENABLE_NOTIFICATIONS=true
GENERATE_SOURCEMAP=true

# ====================================
# EMAIL CONFIGURATION
# ====================================
EMAIL_HOST=smtp.gmail.com
EMAIL_USER=your_email@domain.com
EMAIL_PASS=your_email_password

# ====================================
# LOGGING & DEBUGGING
# ====================================
LOG_LEVEL=Debug

# ====================================
# PRODUCTION ONLY SETTINGS
# ====================================
# These should only be set in .env.production
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem
